# Neon Database
DATABASE_URL="postgresql://user:password@host/database-name?sslmode=require&channel_binding=require"

# Neon Auth
NEON_API_KEY=your_neon_api_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_gemini_api_key_here

# OpenRouter (Optional: replace Gemini)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Auth - NextAuth Configuration
# For local development: use http://localhost:3000 or http://192.168.56.1:3000
# For Vercel production: use https://your-project.vercel.app
NEXTAUTH_URL=https://your-project.vercel.app
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
